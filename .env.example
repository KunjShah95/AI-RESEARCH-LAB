# Database
DATABASE_URL=postgresql://localhost:5432/paper_analyzer

# Encryption
CRYPTO_SECRET_KEY=your-secret-key-change-in-production
ENCRYPTION_KEY=your-encryption-key-change-in-production

# LLM Provider Keys (add only the ones you use)

## OpenAI (Paid, ~$0.03/1k tokens for GPT-4o)
# OPENAI_API_KEY=sk-...

## Anthropic Claude (Paid, ~$0.03/1k tokens for Claude 3.5)
# ANTHROPIC_API_KEY=sk-ant-...

## Groq (Free tier available, very fast)
# GROQ_API_KEY=...
# Free models: llama-3.1-70b-versatile, mixtral-8x7b-32768, gemma-7b-it

## OpenRouter (Free tier + access to 100+ models)
# OPENROUTER_API_KEY=...
# Free models available: mistral-7b, neural-chat-7b, etc.

## Mistral AI (Paid, ~$0.14/1M tokens)
# MISTRAL_API_KEY=...

## Google Gemini (Free tier available)
# GOOGLE_API_KEY=...
# Free models: gemini-1.5-flash, gemini-2.0-flash-exp

## NVIDIA NIM (Free tier available)
# NVIDIA_API_KEY=...
# Free models: meta/llama-3.1-70b-instruct

# Authentication
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Rate Limits
DEFAULT_RATE_LIMIT=60
MAX_RATE_LIMIT=1000

# Cache
CACHE_ENABLED=true
CACHE_TTL=3600

# Redis (Optional)
# REDIS_URL=redis://localhost:6379

# Research APIs
S2_API_KEY=your-semantic-scholar-key

# Debug
DEBUG=false
